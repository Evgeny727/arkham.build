{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "sortPackageJson": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/dist",
    "**/coverage",
    "**/playwright-report",
    "**/test-results",
    "**/.wrangler",
    "test/fullstack/arkhamdb-docker",
    "**/*.html",
    "**/*.md",
    "**/*.toml",
    "**/*.yaml",
    "**/*.yml"
  ]
}
