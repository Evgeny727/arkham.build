# Endpoint of the arkham.build backend.
VITE_API_LEGACY_URL="https://api.arkham.build"

# Base URL of card image bucket.
VITE_CARD_IMAGE_URL="https://assets.arkham.build"

# Name of the app.
VITE_PAGE_NAME="arkham.build"

# Public contact email for privacy and support requests.
VITE_ADMIN_EMAIL="admin@example.com"

# Public legal notice. Escape new lines as \n.
VITE_LEGAL_NOTICE="Example legal notice\nEmail: info@example.com"

# Base URL of arkhamdb.
VITE_ARKHAMDB_BASE_URL="https://arkhamdb.com"

# Base URL of the recommendation API.
VITE_API_URL="https://api.arkham.build"

# Controls whether the preview banner is shown.
VITE_SHOW_PREVIEW_BANNER="false"

# Cloudflare Turnstile site key. Leave empty to disable on signup.
# see: https://developers.cloudflare.com/turnstile/troubleshooting/testing/#test-sitekeys
VITE_TURNSTILE_SITE_KEY=""
