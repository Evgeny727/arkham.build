# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

SECRETS=$(kamal secrets fetch --adapter 1password --account ${OP_ACCOUNT} --from ${OP_VAULT}/${OP_ITEM} INGEST_URL_ARKHAMDB_DECKLISTS CLOUDFLARE_API_TOKEN CLOUDFLARE_ZONE_ID KAMAL_REGISTRY_PASSWORD KAMAL_REGISTRY_USERNAME POSTGRES_PASSWORD DATABASE_URL ADMIN_API_KEY)

INGEST_URL_ARKHAMDB_DECKLISTS=$(kamal secrets extract INGEST_URL_ARKHAMDB_DECKLISTS $SECRETS)
CLOUDFLARE_API_TOKEN=$(kamal secrets extract CLOUDFLARE_API_TOKEN $SECRETS)
CLOUDFLARE_ZONE_ID=$(kamal secrets extract CLOUDFLARE_ZONE_ID $SECRETS)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)
KAMAL_REGISTRY_USERNAME=$(kamal secrets extract KAMAL_REGISTRY_USERNAME $SECRETS)
POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD $SECRETS)
DATABASE_URL=$(kamal secrets extract DATABASE_URL $SECRETS)
ADMIN_API_KEY=$(kamal secrets extract ADMIN_API_KEY $SECRETS)
