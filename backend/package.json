{
  "name": "@arkham-build/backend",
  "main": "src/main.ts",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "compose:up": "COMPOSE_MENU=0 docker compose up -d --build",
    "compose:down": "docker compose down",
    "dbmate": "dbmate",
    "dbmate:new:pgboss": "node scripts/create-pg-boss-migration.mjs",
    "dev": "node --watch --experimental-strip-types --env-file=.env src/main.ts",
    "dev:worker": "node --watch --experimental-strip-types --env-file=.env src/worker.ts",
    "inspect:web": "node --inspect=localhost:9229 --experimental-strip-types --env-file=.env src/main.ts",
    "inspect:worker": "node --inspect=localhost:9230 --experimental-strip-types --env-file=.env src/worker.ts",
    "generate:database-types": "kysely-codegen --out-file src/db/schema.types.ts",
    "ingest": "npm run ingest:json-data && npm run ingest:arkhamdb-decklists",
    "ingest:json-data": "node --experimental-strip-types --env-file-if-exists=.env --env-file-if-exists=../.env src/scripts/ingest/index.ts",
    "ingest:arkhamdb-decklists": "node --experimental-strip-types --env-file-if-exists=.env --env-file-if-exists=../.env src/scripts/ingest-arkhamdb-decklists.ts",
    "purge:cloudflare-cache": "node --experimental-strip-types --env-file-if-exists=.env --env-file-if-exists=../.env src/scripts/purge-cloudflare-cache.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fast-csv/parse": "5.0.5",
    "@hono/node-server": "2.0.2",
    "async-mutex": "0.5.0",
    "dbmate": "2.31.0",
    "hono": "4.12.25",
    "kysely": "0.28.17",
    "nodemailer": "9.0.1",
    "pg": "8.19.0",
    "pg-boss": "12.18.2",
    "tar": "7.5.16"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.3",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/nodemailer": "7.0.5",
    "@types/pg": "8.16.0",
    "kysely-codegen": "0.20.0"
  }
}
